<%- include('../partials/header', { title, description, showSearch, currentPath }) %>

<section class="tool-page card">
  <h1>Base64 Encoder / Decoder</h1>
  <p class="muted">Encode text/files to Base64 and decode Base64 back to text.</p>

  <div class="inline-controls">
    <label class="inline-check">
      <input id="autoDetect" type="checkbox" checked />
      Auto-detect mode
    </label>
    <input id="fileInput" type="file" />
  </div>

  <div class="two-col">
    <div>
      <label for="plainText">Plain Text</label>
      <textarea id="plainText" rows="10" placeholder="Enter plain text"></textarea>
      <button id="encodeBtn" class="btn" type="button">Encode →</button>
    </div>
    <div>
      <label for="base64Text">Base64</label>
      <textarea id="base64Text" rows="10" placeholder="Enter base64"></textarea>
      <button id="decodeBtn" class="btn ghost" type="button">Decode →</button>
    </div>
  </div>

  <div class="btn-row wrap">
    <button id="copyBase64" class="btn ghost" type="button">Copy Base64</button>
    <button id="copyPlain" class="btn ghost" type="button">Copy Plain Text</button>
    <button id="downloadBase64" class="btn ghost" type="button">Download .txt</button>
  </div>

  <p id="base64Status" class="muted"></p>
</section>

<%- include('../partials/footer', { pageScript }) %>

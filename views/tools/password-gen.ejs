<%- include('../partials/header', { title, description, showSearch, currentPath }) %>

<section class="tool-page card">
  <h1>Password Generator</h1>
  <p class="muted">Generate secure passwords with configurable rules and batch mode.</p>

  <div class="inline-controls">
    <label for="lengthRange">Length: <strong id="lengthValue">16</strong></label>
    <input id="lengthRange" type="range" min="8" max="64" value="16" />
  </div>

  <div class="inline-controls wrap">
    <label class="inline-check"><input id="useUpper" type="checkbox" checked /> Uppercase</label>
    <label class="inline-check"><input id="useLower" type="checkbox" checked /> Lowercase</label>
    <label class="inline-check"><input id="useNumbers" type="checkbox" checked /> Numbers</label>
    <label class="inline-check"><input id="useSymbols" type="checkbox" checked /> Symbols</label>
  </div>

  <div class="inline-controls">
    <label for="batchCount">Batch count</label>
    <input id="batchCount" type="number" min="1" max="20" value="1" />
    <button id="generatePasswords" class="btn" type="button">Generate</button>
  </div>

  <div class="strength-wrap">
    <span id="strengthLabel">Strength: fair</span>
    <div class="strength-meter"><span id="strengthBar"></span></div>
  </div>

  <div id="passwordResults" class="password-results"></div>
</section>

<%- include('../partials/footer', { pageScript }) %>

<%- include('../partials/header', { title, description, showSearch, currentPath }) %>

<section class="tool-page card">
  <h1>Color Picker & Converter</h1>
  <p class="muted">Pick a color and convert across HEX, RGB, HSL, and CMYK instantly.</p>

  <label for="colorInput">Select Color</label>
  <input id="colorInput" type="color" value="#5a67d8" />

  <div class="stats-grid">
    <div class="stat">
      <span>HEX</span>
      <strong id="hexValue">#5A67D8</strong>
      <button class="btn ghost copy-btn" data-copy-target="hexValue" type="button">Copy</button>
    </div>
    <div class="stat">
      <span>RGB</span>
      <strong id="rgbValue">rgb(90, 103, 216)</strong>
      <button class="btn ghost copy-btn" data-copy-target="rgbValue" type="button">Copy</button>
    </div>
    <div class="stat">
      <span>HSL</span>
      <strong id="hslValue">hsl(234, 61%, 60%)</strong>
      <button class="btn ghost copy-btn" data-copy-target="hslValue" type="button">Copy</button>
    </div>
    <div class="stat">
      <span>CMYK</span>
      <strong id="cmykValue">cmyk(58%, 52%, 0%, 15%)</strong>
      <button class="btn ghost copy-btn" data-copy-target="cmykValue" type="button">Copy</button>
    </div>
  </div>

  <h2>Generated Palette</h2>
  <div id="palette" class="palette"></div>
</section>

<%- include('../partials/footer', { pageScript }) %>
